# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# PostgreSQL / Redmine database credentials
REDMINE_DB_DATABASE=redmine
REDMINE_DB_USERNAME=redmine
REDMINE_DB_PASSWORD=change-me

# Redmine session secret. Generate with: openssl rand -hex 32
REDMINE_SECRET_KEY_BASE=change-me

{
  "name": "apivista",
  "version": "0.1.0",
  "private": true,
  "description": "FastAPI <-> frontend route linkage visualizer for VSCode",
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./out/vscode-extension/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "apivista.showGraph",
        "title": "ApiVista: Show Route Linkage Graph"
      },
      {
        "command": "apivista.reanalyze",
        "title": "ApiVista: Reanalyze Workspace"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run bundle:webview",
    "bundle:webview": "esbuild src/vscode-extension/webview/main.ts --bundle --outfile=media/webview/bundle.js --format=iife --platform=browser",
    "typecheck:tests": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:integration": "rm -rf out-test-electron && npm run build && tsc -p tsconfig.test-electron.json && node ./out-test-electron/vscode-extension/test/runTest.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cytoscape": "^3.31.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.0.0",
    "glob": "^13.0.6",
    "jsdom": "^25.0.0",
    "mocha": "^11.7.6",
    "prettier": "^3.0.0",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0",
    "web-tree-sitter": "^0.25.10"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.5.38",
    "cytoscape": "^3.34.0",
    "ts-morph": "^23.0.0"
  }
}

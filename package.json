{
  "name": "apivista",
  "displayName": "ApiVista",
  "version": "0.1.0",
  "publisher": "kumamoto-kouki",
  "description": "FastAPI <-> frontend route linkage visualizer for VSCode",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kumamoto-kouki/ApiVista.git"
  },
  "homepage": "https://github.com/kumamoto-kouki/ApiVista#readme",
  "bugs": {
    "url": "https://github.com/kumamoto-kouki/ApiVista/issues"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./out/vscode-extension/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "apivista.showGraph",
        "title": "ApiVista: ルート連携グラフを表示"
      },
      {
        "command": "apivista.reanalyze",
        "title": "ApiVista: ワークスペースを再解析"
      },
      {
        "command": "apivista.analyzeActiveFile",
        "title": "ApiVista: このファイルのルートを解析"
      },
      {
        "command": "apivista.revealInGraph",
        "title": "ApiVista: この位置の枠をグラフで表示"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "apivista.analyzeActiveFile",
          "when": "resourceExtname == '.py' || resourceExtname == '.ts' || resourceExtname == '.js' || resourceExtname == '.vue'",
          "group": "apivista@1"
        },
        {
          "command": "apivista.revealInGraph",
          "when": "resourceExtname == '.py' || resourceExtname == '.ts' || resourceExtname == '.js' || resourceExtname == '.vue'",
          "group": "apivista@1"
        }
      ],
      "explorer/context": [
        {
          "command": "apivista.analyzeActiveFile",
          "when": "resourceExtname == '.py' || resourceExtname == '.ts' || resourceExtname == '.js' || resourceExtname == '.vue'",
          "group": "apivista@1"
        }
      ]
    }
  },
  "scripts": {
    "copy-wasm": "mkdir -p media/wasm && cp node_modules/web-tree-sitter/tree-sitter.wasm media/wasm/ && cp node_modules/tree-sitter-wasms/out/tree-sitter-python.wasm media/wasm/",
    "build": "tsc -p tsconfig.json && npm run bundle:webview && npm run copy-wasm",
    "bundle:webview": "esbuild src/vscode-extension/webview/main.ts --bundle --outfile=media/webview/bundle.js --format=iife --platform=browser",
    "package": "npm run build && npx vsce package --allow-missing-repository",
    "typecheck:tests": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:integration": "rm -rf out-test-electron && npm run build && tsc -p tsconfig.test-electron.json && node ./out-test-electron/vscode-extension/test/runTest.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cytoscape": "^3.31.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "cytoscape": "^3.34.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.0.0",
    "glob": "^13.0.6",
    "jsdom": "^25.0.0",
    "mocha": "^11.7.6",
    "prettier": "^3.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0",
    "tree-sitter-wasms": "^0.1.13",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.5.38",
    "ts-morph": "^23.0.0",
    "web-tree-sitter": "^0.25.10"
  }
}
